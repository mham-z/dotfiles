// =============================================================================
//
// Waybar configuration
//
// Configuration reference: https://github.com/Alexays/Waybar/wiki/Configuration
//
// =============================================================================

{
	// -------------------------------------------------------------------------
	// Global configuration
	// -------------------------------------------------------------------------

	"layer": "top",

	"position": "left",

	// If height property would be not present, it'd be calculated dynamically
	"width": 40,

        "margin-left": 0,
        "margin-top": 10,
        "margin-right": 0,
        "margin-bottom": 10,

	"modules-left": [
		"clock#time"
	],
	"modules-center": [
		"hyprland/workspaces"
	],
	"modules-right": [
		"group/menu",
		"custom/backlight",
		"pulseaudio",
		"bluetooth",
		"network",
		"battery"
	],


	// -------------------------------------------------------------------------
	// Modules
	// -------------------------------------------------------------------------

	"group/menu": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 200,
			"children-class": "iconsmenu",
			"transition-left-to-right": false,
			"click-to-reveal": false
		},
		"modules": [
			"custom/menumain",
			"tray",
			"idle_inhibitor",
			"custom/hyprpicker"
		]
	},

	"custom/menumain": {
		"interval": "once",
		"format": "َ°‡ک",
		"tooltip": true,
		"tooltip-format": "Extras"
	},
	
	"idle_inhibitor": {
            "format": "{icon}",
            "format-icons": {
                "activated": "َ°…¶",
                "deactivated": "َ°¾ھ"
            }
        },
      
	"battery": {
		"interval": 5,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon}",
                "format-icons": {
                    "default": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
                    "charging": ["َ°¢ں", "َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"]
                },
		"tooltip": true,
		"tooltip-format": "Percentage: {capacity}%\nHealth: {health}%\nPower draw: {power}W\n{timeTo}"
	},

	"custom/backlight": {
		"interval": "once",
		"format": "َ°–¨",
		"on-scroll-up": "brightnessctl -e2.4 -n15 set 5%+ && ~/dotfiles/home/.config/hypr/scripts/swayosd-fake-brightness",
		"on-scroll-down": "brightnessctl -e2.4 -n15 set 5%- && ~/dotfiles/home/.config/hypr/scripts/swayosd-fake-brightness",
		"tooltip": true,
		"tooltip-format": "Brightness"
	},        
        
	"custom/hyprpicker": {
		"interval": "once",
		"format": "َ°ˆٹ",
		"on-click": "color=$(hyprpicker -a 2>/dev/null) && [[ $color == \\#* ]] && notify-send \"Hyprpicker\" \"Color: $color\nThis has been saved to your clipboard.\"",
		"tooltip": true,
		"tooltip-format": "Hyprpicker"
	},

	"tray": {
		"icon-size": 21,
		"spacing": 8
	},

	"clock#time": {
		"interval": 1,
		"format": "{:%I\n%M}",
		"tooltip": true,
		"tooltip-format": "{:%r\n%A, %d %B %Y}"
	},

	"network": {
		"interval": 5,
		"format-wifi": "{icon}", // Icon: wifi
		"format-ethernet": "ï‍–", // Icon: ethernet
		"format-disconnected": "َ°¤®",
		"tooltip-format": "{ifname}: {ipaddr}\nSSID: {essid}\nFrequency: {frequency}\nSignal: {signalStrength}% ({signaldBm})",
		"on-click": "kitty --class=\"nmtui\" nmtui",
		"format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"]
	},

	"hyprland/workspaces": {
		"all-outputs": false,
		"disable-scroll": false,
		"persistent-workspaces": false,
		"format": "{icon}",
		"format-icons": {
			"active": "îھ«",
			"default": "î®ٹ"
		},
		"on-scroll-down": "hyprctl dispatch workspace e+1",
		"on-scroll-up": "hyprctl dispatch workspace e-1"
	},

	"pulseaudio": {
		"scroll-step": 5,
		"format": "{icon}",
		"format-bluetooth": "{icon}",
		"format-muted": "َ°‌ں",
		"format-icons": {
			"default": ["َ°•؟", "َ°–€", "َ°•¾"]
		},
		"tooltip-format": "{volume}%",
		"max-volume": 200,
		"on-click": "swayosd-client --output-volume mute-toggle",
		"on-click-right": "pavucontrol",
		"on-click-middle": "swayosd-client --playerctl play-pause",
		"on-scroll-down": "swayosd-client --output-volume lower --max-volume 150",
		"on-scroll-up": "swayosd-client --output-volume raise --max-volume 150"
	},

	"bluetooth": {
		"format": "َ°‚¯",
		"format-disabled": "َ°‚²",
		"format-connected": "َ°‚¯",
		"tooltip-format": "{controller_alias}\t{controller_address}",
		"tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
		"tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
		"tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
		"on-click": "blueman-manager"
	}
}
